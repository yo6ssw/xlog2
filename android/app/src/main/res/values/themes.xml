<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- A minimal NoActionBar base; the real colors come from Compose's
         XlogTheme. This only governs the brief pre-Compose window: a DayNight
         window background (see values-night) so there's no flash, and
         transparent system bars to match enableEdgeToEdge(). -->
    <style name="Theme.Xlog2" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/window_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
