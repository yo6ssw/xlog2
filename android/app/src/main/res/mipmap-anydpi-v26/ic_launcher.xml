<?xml version="1.0" encoding="utf-8"?>
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Full-bleed rasterised xlog2-qt.svg (neon glow + text can't be expressed
         as a VectorDrawable, so it's rendered to per-density PNGs). The dark
         background fills any area the launcher's mask reveals past the artwork. -->
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
